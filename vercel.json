{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "^/(api|predict|history|profile|register|login|forgot-password|reset-password|predictions)(.*)",
      "dest": "backend/app.py"
    },
    {
      "src": "^/(.*)",
      "dest": "frontend/$1"
    }
  ]
}